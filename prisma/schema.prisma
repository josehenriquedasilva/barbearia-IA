generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  BARBER
}

enum PlanType {
  BRONZE
  SILVER
}

enum AppointmentStatus {
  CONFIRMED
  CANCELED
}

model Shop {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  phone     String   @db.VarChar(20)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")

  plan       PlanType    @default(BRONZE)

  openingTime      String       @default("09:00") @map("opening_time")
  closingTime      String       @default("19:00") @map("closing_time")

  hasDayOff        Boolean      @default(false) @map("has_day_off")
  dayOff           String?      @map("day_off")

  isClosedSunday   Boolean      @default(true) @map("is_closed_sunday")
  openingSunday    String?      @map("opening_sunday")
  closingSunday    String?      @map("closing_sunday")

  hasLunchBreak    Boolean      @default(false) @map("has_lunch_break")
  lunchStart       String?      @map("lunch_start")
  lunchEnd         String?      @map("lunch_end")

  closedDays ClosedDay[]
  barbers      Barber[]
  services     Service[]
  appointments Appointment[]

  isProcessingChat  Boolean   @default(false) @map("is_processing_chat")

  chatMessages ChatMessage[]

  whatsappInstance String? @unique
  whatsappToken    String?

  @@map("shops")
}

model ClosedDay {
  id     Int     @id @default(autoincrement())
  date   String
  reason String? @db.VarChar(255)

  shopId Int  @map("shop_id")
  shop   Shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, date])
  @@map("closed_days")
}

model Barber {
  id       Int    @id @default(autoincrement())
  name     String @db.VarChar(100)
  email    String @unique @db.VarChar(255)
  password String @db.VarChar(255)
  role     Role   @default(BARBER)

  shopId Int  @map("shop_id")
  shop   Shop @relation(fields: [shopId], references: [id])

  appointments Appointment[]
  exceptions   AvailabilityException[]

  @@map("barbers")
}

model Service {
  id              Int     @id @default(autoincrement())
  name            String  @db.VarChar(100)
  durationMinutes Int     @map("duration_minutes")
  price           Decimal @db.Decimal(10, 2)

  shopId    Int       @map("shop_id")
  shop      Shop      @relation(fields: [shopId], references: [id])
  active    Boolean   @default(true)
  disableAt DateTime?

  appointments Appointment[]

  @@map("services")
}

model Appointment {
  id          Int    @id @default(autoincrement())
  clientName  String @map("client_name") @db.VarChar(255)
  clientPhone String @map("client_phone") @db.VarChar(50)

  shopId Int  @map("shop_id")
  shop   Shop @relation(fields: [shopId], references: [id])

  barberId Int    @map("barber_id")
  barber   Barber @relation(fields: [barberId], references: [id])

  serviceId Int     @map("service_id")
  service   Service @relation(fields: [serviceId], references: [id])

  startTime    DateTime          @map("start_time")
  endTime      DateTime          @map("end_time")
  status       AppointmentStatus @default(CONFIRMED)
  cancelReason String?           @map("cancel_reason") @db.VarChar(255)

  @@map("appointments")
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  clientPhone String @map("client_phone")
  shopId      Int    @map("shop_id")
  shop        Shop   @relation(fields: [shopId], references: [id])

  @@index([clientPhone, shopId])
  @@map("chat_messages")
}

model AvailabilityException {
  id       Int     @id @default(autoincrement())
  barberId Int?    @map("barber_id")
  barber   Barber? @relation(fields: [barberId], references: [id])

  date        DateTime @db.Date
  reason      String   @db.VarChar(255)
  isEmergency Boolean  @default(false) @map("is_emergency")

  @@map("availability_exceptions")
}
